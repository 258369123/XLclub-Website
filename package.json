{
  "name": "xlclub-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "set ASTRO_TELEMETRY_DISABLED=1&& astro dev --host 127.0.0.1 --port 4321",
    "build": "set ASTRO_TELEMETRY_DISABLED=1&& astro build",
    "preview": "npm run build && wrangler dev",
    "check": "set ASTRO_TELEMETRY_DISABLED=1&& astro check",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.0",
    "@astrojs/react": "^5.0.5",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.8",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "7.3.3",
    "wrangler": "^4.95.0"
  },
  "overrides": {
    "vite": "7.3.3"
  }
}
